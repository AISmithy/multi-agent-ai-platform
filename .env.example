# .env.example — copy to .env and fill in values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql://kyc_app_user:password@localhost:5432/kyc_db

# AWS / Document store
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-west-1
S3_BUCKET=kyc-documents-prod

# Sanctions API (ComplyAdvantage)
SANCTIONS_API_KEY=...
SANCTIONS_API_URL=https://api.complyadvantage.com

# OCR (AWS Textract — uses AWS credentials above)
TEXTRACT_REGION=eu-west-1

# Liveness (Onfido)
ONFIDO_API_KEY=...

# Notifications
SENDGRID_API_KEY=...
CRM_WEBHOOK_URL=https://your-crm.com/api/webhooks/kyc

# Circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# SLA settings (seconds)
CASE_SLA_LOW_RISK=300       # 5 minutes
CASE_SLA_MEDIUM_RISK=172800 # 48 hours
CASE_TTL_REDIS=2592000      # 30 days

# Observability
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
